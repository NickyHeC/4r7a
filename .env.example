# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# --- Wiki store + runtime ---
# Deployment mode: local (wiki Markdown stored in ./wiki, gitignored) or
# cloud (wiki Markdown on the VM's persistent storage at /workspace/wiki).
# Leave unset to auto-infer from COMPANY_BRAIN_WIKI_DIR.
COMPANY_BRAIN_MODE=local
# Directory holding the Markdown wiki (source of truth). On a cloud VM this
# points at the mounted persistent volume.
# COMPANY_BRAIN_WIKI_DIR=/workspace/wiki
# Per-member employee wikis (work logs, imports). Defaults to a sibling of the
# company wiki (e.g. ./employee_wiki); on a cloud VM point at the mounted volume.
# COMPANY_BRAIN_EMPLOYEE_WIKI_DIR=/workspace/employee_wiki
# Wiki bot token — write access to the admin-only company-wiki GitHub repo only
# (daily wiki_commit backup). Never grant this token access to the agent repo.
# COMPANY_BRAIN_WIKI_GIT_TOKEN=
# Optional path to the local clone of company-wiki (default: ./.wiki_git).
# COMPANY_BRAIN_WIKI_GIT_DIR=/var/lib/company-brain/wiki_git
# Agent runtime: local (in-process) or cloud (spin up VMs on a cloud fleet).
COMPANY_BRAIN_RUNTIME=local
# VM backend when running agents in VMs. Defaults: smolvm (local mode), smolcloud
# (cloud mode). Override to use another provider that meets the same requirements.
# COMPANY_BRAIN_VM_PROVIDER=smolvm
# Sandbox verification: off (in-process) or smolvm (ephemeral smolvm microVM).
# COMPANY_BRAIN_SANDBOX=off

# --- LLM provider (which model powers every agent) ---
# Single knob, resolved against config/models.yaml. Values: anthropic | openai | glm.
#   anthropic / openai : hosted provider APIs via your key. Default for LOCAL
#                        installs (no GPU needed).
#   glm                : open-source GLM-5 (https://github.com/zai-org/GLM-5)
#                        behind an OpenAI-compatible endpoint (SGLang/vLLM) — no
#                        external tokens billed. Self-hosted on the CLOUD GPU VM,
#                        or a remote open-source host you connect to. Locally
#                        installing GLM-5 is not realistic.
COMPANY_BRAIN_LLM_PROVIDER=anthropic
# Optional: override the model id for the active provider.
# COMPANY_BRAIN_LLM_MODEL=
# Extend the Claude prompt-cache write TTL from 5 min to 1h. Helps recurring
# agents whose intra-run LLM calls (e.g. absorb batches, verify/rework) are
# spaced minutes apart. Read natively by the Claude Agent SDK.
# ENABLE_PROMPT_CACHING_1H=1

# Anthropic (Claude Agent SDK: absorb writer, card_spend, budget_report, subscription_audit)
ANTHROPIC_API_KEY=
# Optional gateway (e.g. a LiteLLM endpoint exposing an Anthropic-compatible API
# backed by an open-source model). The Claude Agent SDK reads this natively.
# ANTHROPIC_BASE_URL=

# OpenAI (OpenAI Agents SDK specialists)
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# GLM-5 (open-source; OpenAI-compatible server). No external tokens.
# Easiest: install via Ollama (`ollama pull glm-5`) — it serves an OpenAI-compatible
# API at :11434/v1. Cloud: self-hosted on the GPU VM. Local: a remote open-source
# host you connect to. SGLang/vLLM are alternatives (just a different GLM_BASE_URL).
# GLM_BASE_URL=http://localhost:11434/v1
# GLM_API_KEY=ollama                 # any non-empty value; Ollama ignores it
# Match COMPANY_BRAIN_LLM_MODEL to the Ollama model tag you pulled (e.g. glm-5).

# --- Mercury (CLI wrapper / HTTP fallback) ---
# CLI install: https://mercury.com/api
MERCURY_TOKEN=
MERCURY_ENV=production            # production | sandbox

# --- Ramp (accessed via MCP) ---
# Docs: https://docs.ramp.com/developer-api/v1/ramp-mcp
RAMP_TOKEN=
# Launch a local stdio Ramp MCP server (default), or set RAMP_MCP_URL for a hosted one.
RAMP_MCP_COMMAND=uvx
RAMP_MCP_ARGS=ramp-mcp
# RAMP_MCP_URL=

# --- Slack (operations department; wiki bot required, weave optional) ---
# Wiki bot (@wiki): passive ingest, ask_wiki, commands. Required for Slack platform.
SLACK_WIKI_BOT_TOKEN=
# Socket Mode app-level token (local installs). Omit when using HTTP Events on cloud.
# SLACK_WIKI_APP_TOKEN=
# HTTP Events signing secret (cloud installs using --http).
# SLACK_WIKI_SIGNING_SECRET=
# Legacy alias — use SLACK_WIKI_BOT_TOKEN instead
SLACK_BOT_TOKEN=
# Weave bot (@weave): system change requests. Optional add-on.
# SLACK_WEAVE_BOT_TOKEN=
# SLACK_WEAVE_APP_TOKEN=

# --- Gmail (operations department; MCP + REST) ---
# Posture: read + labels + DRAFT compose only — agents never send email.
# REST (gmail_rest.py) also needs gmail.modify for label/archive/read state.
# Provider: official (Google-hosted Gmail MCP, default) or composio.
GMAIL_MCP_PROVIDER=official
# Gmail API user id for REST calls (usually "me" or the connected email).
GMAIL_MAILBOX=me
# Service profile: executive_assistant (default) | employee | service_account
# Overrides config/operations.yaml gmail.profile for this deploy.
# GMAIL_PROFILE=executive_assistant
#
# Official Gmail MCP (Google Workspace Developer Preview). HTTP + OAuth 2.0,
# scopes gmail.readonly + gmail.compose + gmail.modify. Enable gmail.googleapis.com +
# gmailmcp.googleapis.com in your Google Cloud project, configure the OAuth
# consent screen with those scopes, and create an OAuth client.
# Docs: https://developers.google.com/workspace/gmail/api/guides/configure-mcp-server
GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Access token from the OAuth consent flow (sent as a Bearer token).
GMAIL_OAUTH_ACCESS_TOKEN=
#
# Composio Gmail MCP (optional — less setup, managed OAuth/token refresh).
# Docs: https://composio.dev/toolkits/gmail
COMPOSIO_API_KEY=
# Pre-created Composio MCP/server URL; leave blank to mint a Tool Router session
# via the composio SDK using COMPOSIO_USER_ID.
COMPOSIO_GMAIL_MCP_URL=
COMPOSIO_USER_ID=company-brain

# --- Linear (engineering department; GraphQL + optional MCP/CLI) ---
# Personal API key from Linear → Settings → Security & Access.
LINEAR_API_KEY=
# Optional OAuth token (Bearer) instead of API key.
# LINEAR_OAUTH_ACCESS_TOKEN=
# Optional: delegate issue create to `linear` CLI (joa23/linear-cli, etc.)
# LINEAR_USE_CLI=0
# Comma-separated mailboxes for duplicate_across_mailboxes dedupe.
# GMAIL_CONNECTED_MAILBOXES=me,ceo@company.com

# --- Granola (operations department; read-only meeting notes API) ---
# Docs: https://docs.granola.ai/introduction
# Business plan: one key per member (personal-notes scope).
# GRANOLA_MEMBER_KEYS=alice:grn_...,bob:grn_...
# Or per-label: GRANOLA_API_KEY_ALICE=grn_...
# Enterprise plan: single key with public-notes scope (Team space).
# GRANOLA_API_KEY=grn_...
# GRANOLA_MODE=business  # override config/operations.yaml granola.mode

# --- Google Calendar (operations department; read + book meetings) ---
# Official MCP: https://calendarmcp.googleapis.com/mcp/v1
# Reuses GMAIL OAuth token when the same client includes calendar scopes.
# GCAL_OAUTH_ACCESS_TOKEN=   # optional override
# GCAL_MCP_URL=https://calendarmcp.googleapis.com/mcp/v1
# GCAL_DAILY_AGENDA=0        # set 1 + slack_user to enable morning DM
# GCAL_DAILY_AGENDA_SLACK_USER=U01234567

# --- Admin console (private mesh; not member bridge) ---
# Local-dev password login (password_login: true in admin_console.yaml).
# ADMIN_CONSOLE_PASSWORD=
# ADMIN_CONSOLE_SESSION_SECRET=
# Google Workspace OIDC (sso.enabled: true in admin_console.yaml).
# ADMIN_CONSOLE_GOOGLE_CLIENT_ID=
# ADMIN_CONSOLE_GOOGLE_CLIENT_SECRET=
# Public base URL for OAuth redirect (default http://127.0.0.1:8780).
# ADMIN_CONSOLE_PUBLIC_BASE_URL=http://127.0.0.1:8780
