# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# --- Anthropic (Claude Agent SDK: ramp_card_spend, budget_report, subscription_audit) ---
ANTHROPIC_API_KEY=

# --- Mercury (CLI wrapper / HTTP fallback) ---
# CLI install: https://mercury.com/api
MERCURY_TOKEN=
MERCURY_ENV=production            # production | sandbox

# --- Ramp (accessed via MCP) ---
# Docs: https://docs.ramp.com/developer-api/v1/ramp-mcp
RAMP_TOKEN=
# Launch a local stdio Ramp MCP server (default), or set RAMP_MCP_URL for a hosted one.
RAMP_MCP_COMMAND=uvx
RAMP_MCP_ARGS=ramp-mcp
# RAMP_MCP_URL=

# --- Slack (slack-sdk: finance notifications to #finance) ---
SLACK_BOT_TOKEN=
