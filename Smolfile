# Smolfile — reproducible VM spec for running company-brain agents.
# Format: https://github.com/smol-machines/smolvm (Smol Machines / smolvm).
# Docs: https://smolmachines.com/
#
# Default backends: smolvm locally, smol cloud in production. Any cloud VM service
# that satisfies the same requirements (CLI, nested VM spin-up, persistent volume,
# cron or persistent managers) can consume an equivalent spec.
#
# Each agent (or the manager fleet) runs in an isolated microVM. The wiki lives
# on a shared volume mounted at /workspace/wiki so the Markdown source of truth
# is consistent across every VM in the fleet. Egress is locked to the APIs the
# agents actually use.

image = "python:3.12"
net = true

[network]
allow_hosts = [
  "api.notion.com",
  "api.mercury.com",
  "api.ramp.com",
  "slack.com",
  "api.github.com",
  # LLM providers (see config/models.yaml + COMPANY_BRAIN_LLM_PROVIDER)
  "api.anthropic.com",
  "api.openai.com",
  # Open-source GLM-5 (cloud option): served via Ollama (OpenAI-compatible at
  # :11434/v1). Add the host here only when GLM_BASE_URL points off-VM; an Ollama
  # server colocated on the same VM / private network needs no allow-host entry.
  # "your-glm-host:11434",
  # Gmail (operations) — official Google-hosted Gmail MCP + OAuth
  "gmailmcp.googleapis.com",
  "gmail.googleapis.com",
  "oauth2.googleapis.com",
  "accounts.google.com",
  # Gmail (operations) — optional Composio-hosted Gmail MCP
  "backend.composio.dev",
  # Linear (engineering) — GraphQL API + official MCP
  "api.linear.app",
  "mcp.linear.app",
  # Granola (operations) — meeting notes REST API
  "public-api.granola.ai",
  # Discord (growth) — community Gateway + REST
  "discord.com",
  "gateway.discord.gg",
  # Google Ads (growth) — Ads API + OAuth
  "googleads.googleapis.com",
  "oauth2.googleapis.com",
  "accounts.google.com",
  "www.googleapis.com",
  # PostHog (product) — private REST API (US / EU cloud)
  "us.posthog.com",
  "eu.posthog.com",
  # Google Calendar (operations) — REST + official MCP
  "calendarmcp.googleapis.com",
  "calendar.googleapis.com",
]

[dev]
init = ["pip install -e ."]
# The shared wiki volume (persistent cloud storage in production). COMPANY_BRAIN_WIKI_DIR
# should point here so all agents read/write the same Markdown source of truth.
# Employee wikis live in a sibling mount (COMPANY_BRAIN_EMPLOYEE_WIKI_DIR).
volumes = ["./wiki:/workspace/wiki", "./employee_wiki:/workspace/employee_wiki"]

[auth]
ssh_agent = true
